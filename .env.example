# ── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://grameen:grameen_secret@localhost:5432/grameen_reach
DB_PASSWORD=grameen_secret

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── MinIO (Object Storage) ───────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=grameen-reach

# ── AI Providers (at least one required for AI features) ────────────────────
# Google Gemini – https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (fallback) – https://console.groq.com/keys
GROQ_API_KEY=

# Tavily (web search augmentation for price-coach when no mandi data) – https://tavily.com
# Optional. When set, price-coach will fetch current web prices for commodities
# that don't appear in the local mandi list.
TAVILY_API_KEY=

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
